{
  "name": "shift-scheduler",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"tsx server/index.ts\" \"vite\"",
    "api": "tsx server/index.ts",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.client.json",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:nuke": "docker compose down -v",
    "db:import": "tsx scripts/import-json-to-mysql.ts",
    "test": "tsx server/scheduler.test.ts && tsx server/trades.test.ts && tsx server/blocks.test.ts && tsx shared/holidays.test.ts",
    "test:e2e": "node --loader tsx/esm ./node_modules/@playwright/test/cli.js test --config=playwright.config.cjs"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "mysql2": "^3.22.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.25",
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^5.4.8"
  }
}

    "test": "node server/scheduler.test.js && node server/trades.test.js && node server/blocks.test.js",
    "test:e2e": "playwright test --config=playwright.config.cjs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^6.0.3",
    "vite": "^5.4.8"
  }
}

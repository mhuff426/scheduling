{
  "name": "shift-scheduler",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"node server/index.js\" \"vite\"",
    "api": "node server/index.js",
    "build": "vite build",
